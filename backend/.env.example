# Copy to backend/.env (git-ignored) for local dev. In prod these are Railway
# env vars. Never commit real values.

# --- Core ---
ENVIRONMENT=development
# Local dev: points at the Postgres from the repo-root docker-compose.yml.
# In prod/staging, Railway injects this as ${{Postgres.DATABASE_URL}} per env.
DATABASE_URL=postgresql://pfa:pfa@localhost:5432/pfa

# Browser origins allowed to call the API (CORS, Phase 8). Comma-separated.
# Dev: the Next.js dev server. Prod: the deployed frontend's Railway URL.
CORS_ALLOW_ORIGINS=http://localhost:3000

# The single app user. All data attaches to this user's row; /auth/login checks a
# password against the same row. Set the password once via:
#   python -m app.set_password
APP_USER_EMAIL=owner@localhost

# --- Secrets ---
# HS256 session-JWT signing key (hand-rolled auth, Phase 7a). Required to log in.
#   generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# Fernet key(s) for encrypting Plaid access_tokens at rest (Phase 2).
# Comma-separated, NEWEST FIRST — one key is the normal case; two appear only
# mid-rotation (new,old). Rotation runbook is in app/crypto.py.
#   generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ACCESS_TOKEN_ENC_KEY=

# --- Plaid (Sandbox while building; used from Phase 2) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Public HTTPS webhook URL (deployed only). Empty locally — no public URL.
# In Railway: https://<your-service>.up.railway.app/webhooks/plaid
PLAID_WEBHOOK_URL=
