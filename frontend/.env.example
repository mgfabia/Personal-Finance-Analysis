# Copy to frontend/.env.local (git-ignored) for dev.
# The frontend only ever talks to our backend API and to Plaid Link — never to
# Plaid data endpoints, and it never sees the Plaid secret or access_token.
#
# NOTE: NEXT_PUBLIC_* vars are inlined at BUILD time (baked into the bundle), not
# read at runtime. In prod, set NEXT_PUBLIC_API_URL on the Railway frontend service
# to the backend's public URL BEFORE/at build; changing it later requires a rebuild.
NEXT_PUBLIC_API_URL=http://localhost:8000
